ucloud pgsql	use=pgsql	short=Manipulate UPgSQL on UCloud platform
ucloud pgsql backup	use=backup	short=List and manipulate backups of UPgSQL instances
ucloud pgsql backup download	use=download	short=Display download URLs of a UPgSQL backup
  flag=backup-id	short=	default=	required=true
  flag=instance-id	short=	default=	required=true
  flag=project-id	short=	default=	required=
  flag=region	short=	default=	required=
  flag=zone	short=	default=	required=
