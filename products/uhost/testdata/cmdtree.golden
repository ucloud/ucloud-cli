  flag=group-name	short=	default=	required=true
  flag=project-id	short=	default=	required=
  flag=region	short=	default=	required=
  flag=remark	short=	default=	required=
ucloud uhost isolation-group delete	use=delete	short=Delete isolation group instances
  flag=group-id	short=	default=[]	required=true
