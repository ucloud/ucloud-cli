ucloud eip	use=eip	short=List,allocate and release EIP
ucloud eip allocate	use=allocate	short=Allocate EIP
  flag=bandwidth-mb	short=	default=0	required=true
  flag=charge-type	short=	default=Month	required=
  flag=count	short=	default=1	required=
  flag=group	short=	default=Default	required=
  flag=line	short=	default=	required=
